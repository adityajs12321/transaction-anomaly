# Copy to .env (optional). Without a key, LLM steps are marked llm_failed
# and the rest of the pipeline still completes.

LLM_PROVIDER=gemini            # gemini | ollama
GEMINI_API_KEY=                # free tier key from https://aistudio.google.com
GEMINI_MODEL=gemini-flash-latest

# Only used when LLM_PROVIDER=ollama (Ollama running on the host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Langfuse observability (optional). Free keys from https://cloud.langfuse.com
# (project settings -> API keys). Tracing is disabled when these are empty.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://localhost:3000
